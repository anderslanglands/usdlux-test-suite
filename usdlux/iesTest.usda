#usda 1.0
(
    subLayers = [
        @./_assets/settings.usda@
    ]
    renderSettingsPrimPath = "/Render/Settings"
    endTimeCode = 30
    framesPerSecond = 24
    metersPerUnit = 1
    startTimeCode = 1
    timeCodesPerSecond = 24
    upAxis = "Y"
)

over "Render"
{
    over "RenderProduct"
    {
        token productName = "iesTest-embree.{frame:04d}.exr"
    }
}

def Scope "materials"
{
    def Material "usdpreviewsurface1"
    {
        token outputs:displacement.connect = </materials/usdpreviewsurface1/usdpreviewsurface1.outputs:displacement>
        token outputs:surface.connect = </materials/usdpreviewsurface1/usdpreviewsurface1.outputs:surface>

        def Shader "usdpreviewsurface1"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 1, 1)
            float inputs:ior = 1
            int inputs:useSpecularWorkflow = 1
            color3f inputs:specularColor = (0,0,0)
            token outputs:displacement
            token outputs:surface
        }
    }
}

def Xform "cameras"
{
    def Camera "iesBottom" (
    )
    {
        float2 clippingRange = (0.001, 1000000)
        float exposure = 0
        float focalLength = 0.0001
        float focusDistance = 5
        float fStop = 0
        float horizontalAperture = 0.0002
        float horizontalApertureOffset = 0
        token projection = "perspective"
        double shutter:close = 0
        double shutter:open = 0
        float verticalAperture = 0.0002
        float verticalApertureOffset = 0
        matrix4d xformOp:transform = ( (-0, 1, 0, 0), (-0.7071067811865476, 0, 0.7071067811865475, 0), (0.7071067811865475, 0, 0.7071067811865476, 0), (-0, 0, 0, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }

    def Camera "iesTop" (
    )
    {
        float2 clippingRange = (0.001, 1000000)
        float exposure = 0
        float focalLength = 0.0001
        float focusDistance = 5
        float fStop = 0
        float horizontalAperture = 0.0002
        float horizontalApertureOffset = 0
        token projection = "perspective"
        double shutter:close = 0
        double shutter:open = 0
        float verticalAperture = 0.0002
        float verticalApertureOffset = 0
        matrix4d xformOp:transform = ( (0, 1, 0, 0), (0.7071067811865475, 0, 0.7071067811865476, 0), (0.7071067811865476, 0, -0.7071067811865475, 0), (0, 0, 0, 1) )
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }
}

def "iesProjectionSphere" (
    prepend apiSchemas = ["MaterialBindingAPI"]
    prepend references = @./_assets/shapes/sphere50x50.usda@
)
{
    rel material:binding = </materials/usdpreviewsurface1>
}

